extends Node

## Глобальная шина событий (Этап 4.9).
## Постройки создаются динамически (через BuildSystem), поэтому HUD не может
## заранее подписаться на их сигналы напрямую — вместо этого постройки шлют
## уведомления здесь, а HUD слушает эту шину.

signal building_damaged(building_name: String)

## Джаггернаут — мини-босс (Этап 4.10). HUD показывает особое предупреждение
## при его появлении и сообщение о победе при его уничтожении.
signal juggernaut_spawned()
signal juggernaut_defeated()

## Финальная фаза эвакуации (Этап 4.11): вызван транспорт — HUD показывает
## предупреждение и обратный отсчёт до зоны эвакуации.
signal evacuation_started()

## Система питания (Этап 4.14): кончилось топливо/разрушен генератор —
## турели простаивают; восстановление питания — обратное оповещение.
signal power_lost()
signal power_restored()

## Пережита ночь (Этап 4.23): цикл день/ночь шлёт это при переходе ночь→день.
## InventorySystem ловит и начисляет очко навыка (3 на старте, +1 за ночь).
signal night_survived()

## Крикун позвал подмогу (Этап 4.13a): HUD показывает предупреждение.
signal screamer_called()

## Босс (Этап 4.13b): спавн/изменение HP/гибель — для HP-бара и алертов HUD.
signal boss_spawned(boss_name: String, max_hp: float)
signal boss_health_changed(hp: float, max_hp: float)
signal boss_defeated()

## Спецволна (Этап 4.13b): объявление типа ночи (босс-ночь/орда) в HUD.
signal special_wave(label: String)

## Убежище разрушено (Этап 5.x): главная цель обороны пала — поражение.
signal shelter_destroyed()

## Игрок умер/возродился (Этап 5.x): смерть НЕ заканчивает игру — игрок уходит
## в режим наблюдателя и возрождается через таймер. HUD показывает отсчёт.
signal player_died()
signal player_respawned()
