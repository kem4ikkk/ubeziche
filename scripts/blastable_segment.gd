extends StaticBody3D

## Размеченный разрушаемый сегмент (Этап 4.12b). Стоит в заранее заданном месте
## периметра (main.tscn) и блокирует проход (слой 1). Только его (группа "blastable")
## может снести C4 инженера — обычные постройки/база НЕ разрушаемы. blast() = открыть
## проход. НЕ входит в группу "building", чтобы C4 не путал его с базой.


func _ready() -> void:
	add_to_group("blastable")


## Подорван зарядом C4 — исчезает, открывая проход.
func blast() -> void:
	print("Сегмент подорван — проход открыт")
	queue_free()
